# ─── RPC & Wallet ────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── Contract & Proof ────────────────────────────────────────────────────────
NFT_CONTRACT=0x6392eb340C2d431E3BB9e3fc0FC579CC54690cFc
MERKLE_PROOF_URL=https://mint.froge.io/merkle/phase2.json
CHAIN_ID=1

# ─── Mint Settings ───────────────────────────────────────────────────────────
# How many tokens to mint per tx (defaults to 1)
MINT_QUANTITY=1

# Override recipient; leave blank to use signer address
MINT_TO=

# Override tx value in ETH; leave blank to auto-detect from proof or use 0
VALUE_ETH=

# ─── Gas Settings (EIP-1559) ─────────────────────────────────────────────────
# Leave blank to fetch from network
MAX_FEE_GWEI=
MAX_PRIORITY_FEE_GWEI=

# Leave blank to use estimated gas × safety multiplier
GAS_LIMIT=

# ─── Runtime Flags ───────────────────────────────────────────────────────────
# Set to false to broadcast a real transaction
DRY_RUN=true

# Enable verbose debug output
DEBUG=true

# ─── Raw Selector Mode ──────────────────────────────────────────────────────
# Override the function selector used for the mint call (4-byte hex).
# When set, the bot builds calldata as: RAW_SELECTOR + abi.encode(RAW_ARG_TYPES, mappedArgs)
# Leave blank to use the default 0x00d52478 selector.
RAW_SELECTOR=
# Comma-separated ABI types for encoding (must match RAW_ARG_MODE count)
RAW_ARG_TYPES=
# Comma-separated arg mapping: how to fill each argument from the proof entry
# Supported values: quantity, allowance, allocation, amount, proof, to
RAW_ARG_MODE=

# ─── Polling Mode ────────────────────────────────────────────────────────────
# Keep looping (refetch proof, rebuild candidates, rerun simulation each cycle)
POLL_ENABLED=true

# Milliseconds between poll cycles
POLL_INTERVAL_MS=1000

# Automatically send tx when a candidate passes (requires DRY_RUN=false)
AUTO_SEND_ON_PASS=true

# Stop the bot after the first successful candidate (or tx)
STOP_AFTER_SUCCESS=true
